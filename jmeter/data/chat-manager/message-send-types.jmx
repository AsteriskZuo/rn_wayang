def root = new JsonSlurper().parseText(rawResponse)
def found = findFirstString(root.value, ['userId', 'userId_1', 'username', 'name'])
if (found == null) {
  def message = 'PRECONDITION_FAILED: message-send-types requires contactUserId, but ChatContactManager.getAllContactsFromServer returned no usable contact'
  prev.setSuccessful(false)
  prev.setResponseCode('PRECONDITION_FAILED')
  prev.setResponseMessage(message)
  prev.setResponseData(message + '\n' + prev.getResponseDataAsString(), 'UTF-8')
  ctx.getThread().stop()
} else {
