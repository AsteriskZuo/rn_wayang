            <stringProp name="Argument.value">easemob-demo#zuoyu</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="newAppId" elementType="Argument">
            <stringProp name="Argument.name">newAppId</stringProp>
            <stringProp name="Argument.value"></stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="deviceResource" elementType="Argument">
            <stringProp name="Argument.name">deviceResource</stringProp>
            <stringProp name="Argument.value"></stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
