          </elementProp>
          <elementProp name="kickDeviceResource" elementType="Argument">
            <stringProp name="Argument.name">kickDeviceResource</stringProp>
            <stringProp name="Argument.value"></stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="pushDeviceId" elementType="Argument">
            <stringProp name="Argument.name">pushDeviceId</stringProp>
            <stringProp name="Argument.value"></stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="pushDeviceToken" elementType="Argument">
