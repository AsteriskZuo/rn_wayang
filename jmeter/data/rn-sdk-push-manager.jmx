          <elementProp name="pushRemindType" elementType="Argument"><stringProp name="Argument.name">pushRemindType</stringProp><stringProp name="Argument.value">all</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="pushDuration" elementType="Argument"><stringProp name="Argument.name">pushDuration</stringProp><stringProp name="Argument.value">0</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="pushStartHour" elementType="Argument"><stringProp name="Argument.name">pushStartHour</stringProp><stringProp name="Argument.value">0</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="pushStartMinute" elementType="Argument"><stringProp name="Argument.name">pushStartMinute</stringProp><stringProp name="Argument.value">0</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="pushEndHour" elementType="Argument"><stringProp name="Argument.name">pushEndHour</stringProp><stringProp name="Argument.value">0</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
