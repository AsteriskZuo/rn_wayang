          <elementProp name="pushDisplayStyle" elementType="Argument"><stringProp name="Argument.name">pushDisplayStyle</stringProp><stringProp name="Argument.value">summary</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="pushTemplateName" elementType="Argument"><stringProp name="Argument.name">pushTemplateName</stringProp><stringProp name="Argument.value">default</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
        </collectionProp>
